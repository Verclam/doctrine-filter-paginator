{
    "name": "verclam/doctrine-filter-paginator",
    "description": "Attribute-based filtering, pagination, and ordering for Symfony + Doctrine",
    "type": "symfony-bundle",
    "license": "AGPL-3.0-or-later",
    "autoload": {
        "psr-4": {
            "Verclam\\DoctrineFilterPaginator\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Khalil Medjahed",
            "email": "khalil.medjahed@verclam.fr"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "symfony/framework-bundle": "^6.4|^7.0",
        "doctrine/orm": "^2.17|^3.0",
        "doctrine/doctrine-bundle": "^2.11",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "*",
        "phpstan/phpstan-doctrine": "*",
        "phpstan/phpstan-symfony": "*"
    },
    "scripts": {
        "phpstan": ["phpstan analyse"],
        "phpcs:check": ["php-cs-fixer check"],
        "phpcs:format": ["php-cs-fixer fix"]
    },
    "extra": {
        "symfony": {
            "bundles": {
                "Verclam\\DoctrineFilterPaginator\\VerclamDoctrineFilterPaginatorBundle": ["all"]
            }
        }
    }
}
